{
  "name": "weixin-mcp",
  "version": "1.7.1",
  "description": "MCP server for WeChat — send text, images, files, videos; receive via webhook; works with Claude Desktop, Cursor, OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "login": "node dist/login.js",
    "dev": "npx ts-node --esm src/index.ts",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "bin": {
    "weixin-mcp": "dist/cli.js",
    "weixin-login": "dist/weixin-login.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
